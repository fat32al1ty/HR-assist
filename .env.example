APP_ENV=local
APP_NAME=Resume Intelligence Platform

POSTGRES_DB=resume_platform
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://resume_user:change-me@postgres:5432/resume_platform

JWT_SECRET_KEY=change-me-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ANALYSIS_MODEL=gpt-5.4-mini
OPENAI_MATCHING_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=none
OPENAI_ANALYSIS_TIMEOUT_SECONDS=60
OPENAI_REQUEST_BUDGET_USD=0.10
OPENAI_ENFORCE_REQUEST_BUDGET=true
OPENAI_RESPONSES_INPUT_USD_PER_1M=2.0
OPENAI_RESPONSES_OUTPUT_USD_PER_1M=8.0
OPENAI_EMBEDDINGS_INPUT_USD_PER_1M=0.13
OPENAI_COST_SAFETY_MULTIPLIER=1.15

STORAGE_DIR=/app/storage
MAX_UPLOAD_SIZE_MB=10
CORS_ORIGINS=["http://localhost:3000"]

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=hr_assistant
VECTOR_SIZE=3072
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

BRAVE_API_KEY=
BRAVE_WEB_SEARCH_URL=https://api.search.brave.com/res/v1/web/search
HH_API_TOKEN=
HH_AREA=113

SUPERJOB_API_KEY=
SUPERJOB_VACANCIES_URL=https://api.superjob.ru/2.0/vacancies/

HABR_CAREER_API_URL=https://career.habr.com/api/v1/vacancies
HABR_CAREER_API_TOKEN=
